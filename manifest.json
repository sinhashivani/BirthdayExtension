{
    "manifest_version": 3,
    "name": "Auto Birthday Rewards Signup",
    "version": "1.0",
    "description": "Automatically signs you up for birthday rewards programs.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs",
        "contextMenus"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_page": "bulk_autofill.html"
}